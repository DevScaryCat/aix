# Copy this file to `.env` (which is gitignored) and paste your real keys there.
# NEVER commit `.env`, and never paste keys into a chat — they'd be stored in logs.
#
# The LLM benchmark reads these via Node's built-in env loader:
#   node --env-file=.env bench/llm-run.mjs

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional overrides (sensible defaults live in bench/llm-run.mjs) ---
# AIX_ANTHROPIC_MODEL=claude-opus-4-8
# AIX_GEMINI_MODEL=gemini-2.5-flash   # default; gemini-2.5-pro needs billing (free tier 429s)
# AIX_BENCH_PROVIDERS=anthropic,gemini   # which providers to run
# AIX_BENCH_TRIALS=3                      # trials per scenario per arm
# AIX_BENCH_MAX_ATTEMPTS=4               # self-correction attempts before giving up
