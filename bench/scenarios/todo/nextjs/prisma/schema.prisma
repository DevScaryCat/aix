generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(cuid())
  name  String
  todos Todo[]
}

model Todo {
  id      String   @id @default(cuid())
  title   String
  done    Boolean  @default(false)
  owner   User     @relation(fields: [ownerId], references: [id])
  ownerId String
  created DateTime @default(now())
}
